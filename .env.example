# Required — fallback Gemini key used for all tasks
GEMINI_API_KEY=

# Optional task-specific Gemini keys (fall back to GEMINI_API_KEY if not set)
GEMINI_LIVE_API_KEY=
GEMINI_QUESTION_FINDER_API_KEY=
GEMINI_EVALUATION_API_KEY=
GEMINI_RESOURCE_CURATION_API_KEY=
GEMINI_UPLOAD_PREP_API_KEY=

# Required for user transcription
ASSEMBLYAI_API_KEY=

# Required for avatar
ANAM_API_KEY=

# Required for external research and improvement resources
FIRECRAWL_API_KEY=

# Optional — set these only when deploying frontend and backend separately
NEXT_PUBLIC_BACKEND_HTTP_URL=
NEXT_PUBLIC_BACKEND_WS_URL=

# Server config
PORT=5000
HOST=0.0.0.0
